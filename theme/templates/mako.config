# ~/.config/mako/config
# AUTO-GENERATED — do not edit. Edit ~/.config/theme/colors.sh and run sync-theme.

anchor=top-right
default-timeout=5000
width=420
outer-margin=20
padding=10
border-size=2
max-icon-size=32
on-button-left=invoke-default-action

background-color={{BG}}ff
text-color={{FG}}ff
border-color={{ACCENT}}ff
progress-color=over {{ACCENT}}44

[urgency=high]
border-color={{COLOR1}}ff
