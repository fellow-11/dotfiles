#!/bin/bash

menu() {
  local prompt="$1"
  local options="$2"
  echo -e "$options" | walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$prompt…" 2>/dev/null
}

present_terminal() {
  ghostty -e bash -c "$1; read -p 'Press enter to close...'"
}

show_main_menu() {
  case $(menu "Go" "󰀻  Apps\n󰧑  Learn\n󰄀  Capture\n󱓞  Toggle\n  Style\n󰒓  Setup\n  Configs\n󰉉  Install\n󰭌  Remove\n  Update\n⏻  System") in
  *Apps*)    walker -p "Launch…" ;;
  *Learn*)   show_learn_menu ;;
  *Capture*) show_capture_menu ;;
  *Toggle*)  show_toggle_menu ;;
  *Style*)   show_style_menu ;;
  *Setup*)   show_setup_menu ;;
  *Configs*) show_configs_menu ;;
  *Install*) show_install_menu ;;
  *Remove*)  show_remove_menu ;;
  *Update*)  show_update_menu ;;
  *System*)  show_system_menu ;;
  esac
}

show_learn_menu() {
  case $(menu "Learn" "  Keybindings\n  CachyOS Wiki\n  Hyprland Wiki\n󰣇  Arch Wiki\n  Neovim Docs\n󱆃  Bash Manual") in
  *Keybindings*) /home/felix/.local/bin/keybindings ;;
  *CachyOS*)     xdg-open https://wiki.cachyos.org/ ;;
  *Hyprland*)    xdg-open https://wiki.hypr.land ;;
  *Arch*)        xdg-open https://wiki.archlinux.org ;;
  *Neovim*)      xdg-open https://neovim.io/doc/ ;;
  *Bash*)        xdg-open https://www.gnu.org/software/bash/manual/ ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "󰹑  Screenshot\n  Screen Recording\n󰈊  Color Picker\n󱄺  OCR Text") in
  *Screenshot*) grimblast copysave area ;;
  *Recording*)  wf-recorder -f ~/Videos/recording.mp4 ;;
  *Color*)      hyprpicker -a ;;
  *OCR*)        grim -g "$(slurp)" - | tesseract stdin stdout | wl-copy ;;
  *) show_main_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "󰍜  Waybar\n󱩫  Screen Shader\n󰔟  Idle Timeout") in
  *Waybar*) pkill -USR1 waybar ;;
  *Shader*) pkill wlsunset || wlsunset -t 4500 ;;
  *Idle*)   pkill hypridle || hypridle ;;
  *) show_main_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "󰸌  Edit Theme\n󰛖  Font\n󰸉  Background\n󰍜  Waybar Position\n󰘇  Corners\n  Gaps\n󱡕  Opacity\n󰂵  Blur\n󰘷  Shadows\n󰤺  Animations\n󰔌  Border Size") in
  "*Edit Theme*")   ghostty -e bash -c 'nvim ~/.config/theme/colors.sh && sync-theme' ;;
  *Font*)         show_font_menu ;;
  *Background*)   show_background_menu ;;
  *Waybar*)       show_waybar_position_menu ;;
  *Corners*)      show_corners_menu ;;
  *Gaps*)         show_gaps_menu ;;
  *Opacity*)      show_opacity_menu ;;
  *Blur*)         show_blur_menu ;;
  *Shadows*)      show_shadows_menu ;;
  *Animations*)   show_animations_menu ;;
  *Border*)       show_border_menu ;;
  *) show_main_menu ;;
  esac
}

show_font_menu() {
  local fonts current chosen
  fonts=$(fc-list :spacing=100 -f "%{family[0]}\n" | grep -v -i -E 'emoji|signwriting' | sort -u)
  current=$(grep 'font-family' ~/.config/waybar/style.css | head -1 | sed "s/.*'\(.*\)'.*/\1/")
  chosen=$(echo "$fonts" | walker --dmenu --width 400 --minheight 1 --maxheight 630 -p "Font (current: $current)…" 2>/dev/null)
  if [[ -n $chosen ]]; then
    sed -i "s/font-family = .*/font-family = \"$chosen\"/" ~/.config/ghostty/config.ghostty
    sed -i "s/font-family: .*/font-family: '$chosen';/g" ~/.config/waybar/style.css
    pkill waybar; waybar & disown
    notify-send -u low "Font set to $chosen"
  else
    show_style_menu
  fi
}

show_background_menu() {
  local chosen
  chosen=$(find ~/.local/share/wallpapers/custom-wallpapers/ -type f 2>/dev/null | walker --dmenu --width 500 --minheight 1 --maxheight 630 -p "Wallpaper…" 2>/dev/null)
  if [[ -n $chosen ]]; then
    sed -i "s|path = .*|path = $chosen|" ~/.config/hypr/hyprpaper.conf
    hyprctl hyprpaper wallpaper ",$chosen" 2>/dev/null || { pkill hyprpaper; hyprpaper & disown; }
    notify-send -u low "Wallpaper set"
  else
    show_style_menu
  fi
}

show_waybar_position_menu() {
  case $(menu "Waybar Position" "󰁝  Top\n󰁅  Bottom") in
  *Top*)
    sed -i 's/"position": "bottom"/"position": "top"/' ~/.config/waybar/config.jsonc
    pkill waybar; waybar & disown ;;
  *Bottom*)
    sed -i 's/"position": "top"/"position": "bottom"/' ~/.config/waybar/config.jsonc
    pkill waybar; waybar & disown ;;
  *) show_style_menu ;;
  esac
}

show_corners_menu() {
  case $(menu "Corners" "󰝣  Sharp\n󰘇  Round") in
  *Sharp*)
    sed -i 's/rounding.*=.*/rounding       = 0,/' ~/.config/hypr/hyprland.lua
    hyprctl reload ;;
  *Round*)
    sed -i 's/rounding.*=.*/rounding       = 10,/' ~/.config/hypr/hyprland.lua
    hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_gaps_menu() {
  case $(menu "Gaps" "  None\n  Small\n  Medium\n  Large") in
  *None*)
    sed -i 's/gaps_in.*=.*/gaps_in  = 0,/' ~/.config/hypr/hyprland.lua
    sed -i 's/gaps_out.*=.*/gaps_out = 0,/' ~/.config/hypr/hyprland.lua
    hyprctl reload ;;
  *Small*)
    sed -i 's/gaps_in.*=.*/gaps_in  = 3,/' ~/.config/hypr/hyprland.lua
    sed -i 's/gaps_out.*=.*/gaps_out = 8,/' ~/.config/hypr/hyprland.lua
    hyprctl reload ;;
  *Medium*)
    sed -i 's/gaps_in.*=.*/gaps_in  = 5,/' ~/.config/hypr/hyprland.lua
    sed -i 's/gaps_out.*=.*/gaps_out = 20,/' ~/.config/hypr/hyprland.lua
    hyprctl reload ;;
  *Large*)
    sed -i 's/gaps_in.*=.*/gaps_in  = 10,/' ~/.config/hypr/hyprland.lua
    sed -i 's/gaps_out.*=.*/gaps_out = 40,/' ~/.config/hypr/hyprland.lua
    hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_opacity_menu() {
  case $(menu "Inactive Opacity" "  100%\n  95%\n  90%\n  80%") in
  *100%) sed -i 's/inactive_opacity.*=.*/inactive_opacity = 1.0,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *95%)  sed -i 's/inactive_opacity.*=.*/inactive_opacity = 0.95,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *90%)  sed -i 's/inactive_opacity.*=.*/inactive_opacity = 0.9,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *80%)  sed -i 's/inactive_opacity.*=.*/inactive_opacity = 0.8,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_blur_menu() {
  case $(menu "Blur" "  Enable\n  Disable") in
  *Enable*)  sed -i '/blur = {/{n; s/enabled.*=.*/enabled   = true,/}' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *Disable*) sed -i '/blur = {/{n; s/enabled.*=.*/enabled   = false,/}' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_shadows_menu() {
  case $(menu "Shadows" "  Enable\n  Disable") in
  *Enable*)  sed -i '/shadow = {/{n; s/enabled.*=.*/enabled      = true,/}' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *Disable*) sed -i '/shadow = {/{n; s/enabled.*=.*/enabled      = false,/}' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_animations_menu() {
  case $(menu "Animations" "  Enable\n  Disable") in
  *Enable*)  sed -i 's/animations = {/{&\n        enabled = true,/' ~/.config/hypr/hyprland.lua 2>/dev/null
             sed -i '/animations = {/{n; s/enabled.*=.*/enabled = true,/}' ~/.config/hypr/hyprland.lua
             hyprctl reload ;;
  *Disable*) sed -i '/animations = {/{n; s/enabled.*=.*/enabled = false,/}' ~/.config/hypr/hyprland.lua
             hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_border_menu() {
  case $(menu "Border Size" "  Thin (1px)\n  Medium (2px)\n  Thick (4px)") in
  *Thin*)   sed -i 's/border_size.*=.*/border_size = 1,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *Medium*) sed -i 's/border_size.*=.*/border_size = 2,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *Thick*)  sed -i 's/border_size.*=.*/border_size = 4,/' ~/.config/hypr/hyprland.lua; hyprctl reload ;;
  *) show_style_menu ;;
  esac
}

show_setup_menu() {
  case $(menu "Setup" "  Audio\n  Wi-Fi\n󰂯  Bluetooth\n󰈆  Default Apps") in
  *Audio*)   ghostty -e pulsemixer ;;
  *Wi-Fi*)   ghostty -e nmtui ;;
  *Bluetooth*) ghostty -e bluetuith ;;
  *Default*) ghostty -e nvim ~/.config/mimeapps.list ;;
  *) show_main_menu ;;
  esac
}

show_configs_menu() {
  case $(menu "Configs" "  Hyprland\n󰍜  Walker\n󰍜  Waybar\n󰎟  Mako\n  Ghostty\n  Dotfiles") in
  *Hyprland*) ghostty -e nvim ~/.config/hypr/hyprland.lua ;;
  *Walker*)   ghostty -e nvim ~/.config/walker/config.toml ;;
  *Waybar*)   ghostty -e nvim ~/.config/waybar/config.jsonc ;;
  *Mako*)     ghostty -e nvim ~/.config/mako/config ;;
  *Ghostty*)  ghostty -e nvim ~/.config/ghostty/config.ghostty ;;
  *Dotfiles*) show_dotfiles_menu ;;
  *) show_main_menu ;;
  esac
}

show_dotfiles_menu() {
  case $(menu "Dotfiles" "  Save\n󰓦  Sync") in
  *Save*) present_terminal "dotfiles-save" ;;
  *Sync*) present_terminal "dotfiles-sync" ;;
  *) show_configs_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "󰣇  Package\n󰣇  AUR\n󰖟  Browser\n  Terminal\n󰵮  Development") in
  *Package*)     show_pkg_install ;;
  *AUR*)         show_aur_install ;;
  *Browser*)     show_install_browser_menu ;;
  *Terminal*)    show_install_terminal_menu ;;
  *Development*) show_install_dev_menu ;;
  *) show_main_menu ;;
  esac
}

show_pkg_install() {
  ghostty -e bash -c '
    pkg_names=$(pacman -Slq | fzf \
      --multi \
      --preview "pacman -Sii {1}" \
      --preview-label="alt-p: toggle, tab: multi-select" \
      --preview-label-pos=bottom \
      --preview-window "down:65%:wrap" \
      --bind "alt-p:toggle-preview" \
      --bind "alt-d:preview-half-page-down,alt-u:preview-half-page-up" \
      --bind "alt-k:preview-up,alt-j:preview-down" \
      --color "pointer:green,marker:green")
    if [[ -n $pkg_names ]]; then
      echo "$pkg_names" | tr "\n" " " | xargs -o sudo pacman -S
    fi
  '
}

show_aur_install() {
  ghostty -e bash -c '
    pkg_names=$(yay -Slq | fzf \
      --multi \
      --preview "yay -Sii {1}" \
      --preview-label="alt-p: toggle, tab: multi-select" \
      --preview-label-pos=bottom \
      --preview-window "down:65%:wrap" \
      --bind "alt-p:toggle-preview" \
      --bind "alt-d:preview-half-page-down,alt-u:preview-half-page-up" \
      --bind "alt-k:preview-up,alt-j:preview-down" \
      --color "pointer:green,marker:green")
    if [[ -n $pkg_names ]]; then
      echo "$pkg_names" | tr "\n" " " | xargs -o yay -S
    fi
  '
}

show_install_browser_menu() {
  case $(menu "Install Browser" "󰖟  Zen\n󰈹  Firefox\n  Chrome") in
  *Zen*)     present_terminal "yay -S zen-browser-bin" ;;
  *Firefox*) present_terminal "sudo pacman -S firefox" ;;
  *Chrome*)  present_terminal "yay -S google-chrome" ;;
  *) show_install_menu ;;
  esac
}

show_install_terminal_menu() {
  case $(menu "Install Terminal" "  Ghostty\n  Kitty\n  Foot") in
  *Ghostty*) present_terminal "yay -S ghostty" ;;
  *Kitty*)   present_terminal "sudo pacman -S kitty" ;;
  *Foot*)    present_terminal "sudo pacman -S foot" ;;
  *) show_install_menu ;;
  esac
}

show_install_dev_menu() {
  case $(menu "Install Dev" "  Node.js\n  Python\n  Rust\n󰟓  Go\n  Docker") in
  *Node*)   present_terminal "sudo pacman -S nodejs npm" ;;
  *Python*) present_terminal "sudo pacman -S python python-pipx" ;;
  *Rust*)   present_terminal "sudo pacman -S rustup && rustup default stable" ;;
  *Go*)     present_terminal "sudo pacman -S go" ;;
  *Docker*) present_terminal "sudo pacman -S docker docker-compose && sudo systemctl enable --now docker" ;;
  *) show_install_menu ;;
  esac
}

show_remove_menu() {
  ghostty -e bash -c '
    pkg_names=$(yay -Qqe | fzf \
      --multi \
      --preview "yay -Qi {1}" \
      --preview-label="alt-p: toggle, tab: multi-select" \
      --preview-label-pos=bottom \
      --preview-window "down:65%:wrap" \
      --bind "alt-p:toggle-preview" \
      --bind "alt-d:preview-half-page-down,alt-u:preview-half-page-up" \
      --bind "alt-k:preview-up,alt-j:preview-down" \
      --color "pointer:red,marker:red")
    if [[ -n $pkg_names ]]; then
      echo "$pkg_names" | tr "\n" " " | xargs -o sudo pacman -Rns
    fi
  '
}

show_update_menu() {
  case $(menu "Update" "  System Packages") in
  *System*) present_terminal "yay -Syu" ;;
  *) show_main_menu ;;
  esac
}

show_system_menu() {
  case $(menu "System" "  Lock\n󰍃  Logout\n󰒲  Suspend\n  Reboot\n󰐥  Shutdown") in
  *Lock*)     hyprlock ;;
  *Logout*)   hyprctl dispatch exit ;;
  *Suspend*)  systemctl suspend ;;
  *Reboot*)   systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) show_main_menu ;;
  esac
}

show_main_menu
