  *) show_install_menu ;;
  esac
}

show_install_dev_menu() {
  case $(menu "Install Dev" "Óīć  Node.js\nÓúľ  Python\nÓě®  Rust\nůįüď  Go\nÓěį  Docker") in
  *Node*)   present_terminal "sudo pacman -S nodejs npm" ;;
  *Python*) present_terminal "sudo pacman -S python python-pipx" ;;
  *Rust*)   present_terminal "sudo pacman -S rustup && rustup default stable" ;;
  *Go*)     present_terminal "sudo pacman -S go" ;;
  *Docker*) present_terminal "sudo pacman -S docker docker-compose && sudo systemctl enable --now docker" ;;
  *) show_install_menu ;;
  esac
}

show_remove_menu() {
  ghostty -e bash -c '
    pkg_names=$(yay -Qqe | fzf \
      --multi \
      --preview "yay -Qi {1}" \
      --preview-label="alt-p: toggle, tab: multi-select" \
      --preview-label-pos=bottom \
      --preview-window "down:65%:wrap" \
      --bind "alt-p:toggle-preview" \
      --bind "alt-d:preview-half-page-down,alt-u:preview-half-page-up" \
      --bind "alt-k:preview-up,alt-j:preview-down" \
      --color "pointer:red,marker:red")
    if [[ -n $pkg_names ]]; then
      echo "$pkg_names" | tr "\n" " " | xargs -o sudo pacman -Rns
    fi
  '
}

show_update_menu() {
  case $(menu "Update" "Ó¨©  System Packages") in
  *System*) present_terminal "yay -Syu" ;;
  *) show_main_menu ;;
  esac
}

show_workspaces_menu() {
  local ws
  ws=$(menu "Workspaces" "1\n2\n3\n4\n5\n6")
  if [[ -n $ws ]]; then
    show_monitor_menu_for_workspace "$ws"
  else
    show_main_menu
  fi
}

show_monitor_menu_for_workspace() {
  local workspace="$1"
  local monitor_list monitor_choice monitor_name

  monitor_list=$(hyprctl monitors -j | jq -r '.[].name')
  monitor_choice=$(echo "$monitor_list" | menu "Move workspace $workspace to‚Ä¶" "$(echo "$monitor_list" | tr '\n' '\n')")

  if [[ -n $monitor_choice ]]; then
    hyprctl dispatch "hl.dsp.workspace.move({ workspace = $workspace, monitor = '$monitor_choice'})"
    notify-send -u low "Workspace $workspace" "Moved to $monitor_choice (until reload)"
  else
    show_workspaces_menu
  fi
}

show_system_menu() {
  case $(menu "System" "ÔÄĺ  Screensaver\nÔÄ£  Lock\nůįćÉ  Logout\nůįí≤  Suspend\nÓęí  Reboot\nůįź•  Shutdown") in
  *Screensaver*) /home/felix/.config/screensaver/omarchy-launch-screensaver ;;
  *Lock*)        hyprlock ;;
  *Logout*)      hyprctl dispatch exit ;;
  *Suspend*)     systemctl suspend ;;
  *Reboot*)      systemctl reboot ;;
  *Shutdown*)    systemctl poweroff ;;
  *)      	 show_main_menu ;;
  esac
}

show_main_menu
